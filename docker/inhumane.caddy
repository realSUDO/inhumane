inhumane.in, www.inhumane.in {
	handle /api/* {
		reverse_proxy inhumane-api:4000
	}
	handle {
		reverse_proxy inhumane-web:3000
	}
}

chat.inhumane.in {
	handle /api/* {
		reverse_proxy inhumane-api:4000
	}
	handle {
		reverse_proxy inhumane-web:3000
	}
}

api.inhumane.in {
	reverse_proxy inhumane-api:4000
}
